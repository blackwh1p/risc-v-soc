# ============================================================
# RISC-V SoC Project — .gitignore
# ============================================================

# --- Vivado generated files ---
*.jou
*.log
*.str
*.mif
*.xpr
*.bit
*.mcs
*.prm
*.ltx
*.runs/
*.cache/
*.hw/
*.ip_user_files/
*.sim/
*.srcs/
.Xil/
vivado_pid*.str
webtalk_*.xml
webtalk*.jou
webtalk*.log

# --- Simulation output ---
*.vvp
*.vcd
*.fst
*.lxt

# --- Compiled software ---
*.elf
*.bin
*.hex
*.map
*.o
*.a

# --- Generated firmware images (regenerate with make compile_*) ---
# test_imem.mem is a static committed test fixture — keep it tracked.
sw/tests/*.mem
!sw/tests/test_imem.mem

# --- Python cache ---
__pycache__/
*.pyc
*.pyo

# --- OS files ---
.DS_Store
Thumbs.db

# --- Editor files ---
.vscode/
.idea/
*.swp
*.swo
*~
